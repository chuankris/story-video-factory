{
  "p001": ["2006年，", "我妈从来不接我的电话。"],
  "p002": ["那年我第一次离家上大学，", "行李箱里塞着新被套，", "口袋里只有一张电话卡。"],
  "p003": ["临走前，妈妈跟我约好：", "每周五晚上七点，", "给家里打个电话。"],
  "p004": ["电话响五声就挂，", "说明我一切都好，", "她不要接，省长途费。"],
  "p005": ["如果她接了，说明家里有事；", "如果我一直响，", "说明我真的需要她。"],
  "p006": ["后来每个周五，", "家里的座机都会准时响起，", "她就站在旁边，一声一声地数。"],
  "p007": ["第五声停下来的时候，", "她才松一口气，", "低头继续择菜。"],
  "p008": ["我在宿舍楼下、小卖部门口、电话亭里，", "把很多想说的话", "都咽了回去。"],
  "p009": ["直到冬天的一个周五，", "电话响了五声，", "还没有停。"],
  "p010": ["第六声刚响，", "妈妈立刻接起。", "电话那头，我沉默了很久。"],
  "p011": ["我只说：妈，我有点想家。", "她说：那你慢慢说，", "妈今天不数铃。"]
}
