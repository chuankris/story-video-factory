{
  "p001": {
    "source": "assets/candidates/p001_001.png",
    "lines": [
      "高考前一周，班里很多人都在聊",
      "苹果三件套。",
      "她听着听着，",
      "把自己裂了角的旧手机",
      "往书包里塞了塞。"
    ]
  },
  "p002": {
    "source": "assets/candidates/p002_001.png",
    "lines": [
      "同桌说，新平板做笔记特别顺；",
      "她笑着点头，",
      "说自己用草稿纸也挺好。"
    ]
  },
  "p003": {
    "source": "assets/candidates/p003_001.png",
    "lines": [
      "晚上回家，",
      "妈妈一边洗碗一边问：",
      "你们说的苹果三件套，",
      "大概要多少钱？"
    ]
  },
  "p004": {
    "source": "assets/candidates/p004_001.png",
    "lines": [
      "她愣了一下，赶紧说：",
      "妈，我开玩笑的，",
      "真的不需要。"
    ]
  },
  "p005": {
    "source": "assets/candidates/p005_001.png",
    "lines": [
      "第二天清晨，",
      "书桌上真的放着一套苹果三件套：",
      "三个苹果，三张小纸条。"
    ]
  },
  "p006": {
    "source": "assets/candidates/p006_001.png",
    "lines": [
      "第一个苹果写着平安，",
      "第二个写着快乐，",
      "第三个写着：",
      "永远不要失去好奇心。"
    ]
  },
  "p007": {
    "source": "assets/candidates/p007_001.png",
    "lines": [
      "第一天进考场前，",
      "她嫌苹果重，走到楼下，",
      "却又偷偷把它放回了书包。"
    ]
  },
  "p008": {
    "source": "assets/candidates/p008_001.png",
    "lines": [
      "考场外下着雨，",
      "妈妈站在人群最后面，",
      "手里攥着透明袋，",
      "里面还有一个没舍得吃的苹果。"
    ]
  },
  "p009": {
    "source": "assets/candidates/p009_001.png",
    "lines": [
      "高考结束那晚，",
      "爸爸和妈妈做了一桌她爱吃的菜，",
      "像是在给她补一场很普通、",
      "却很盛大的庆祝。"
    ]
  },
  "p010": {
    "source": "assets/candidates/p010_001.png",
    "lines": [
      "后来她才知道，",
      "妈妈请了两天假，",
      "每天都说自己只是刚好路过。"
    ]
  },
  "p011": {
    "source": "assets/candidates/p011_001.png",
    "lines": [
      "很多年后她才明白，",
      "妈妈买不起流行里的三件套，",
      "却把平安、快乐和好奇心",
      "都留给了她。"
    ]
  }
}
