# Jimeng browser session (contains login cookies — never commit)
.jimeng-profile*/
jimeng-state.json
*.jimeng-state.json
jimeng-errors/

# Local test artifacts inside episodes
episodes/*/jimeng-test/
episodes/*/jimeng-video-test/
episodes/*/tmp/
episodes/*/runs/

# Provider task state
video-tasks.json

# Episode working assets (keep scripts/outlines in git, not media)
episodes/*/assets/
episodes/*/output/

# Local secrets — never commit
set-env.local.bat
.env*

# Test fixtures
tests/fixture-episode/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
