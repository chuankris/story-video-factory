{
  "_comment": "Jimeng UI selectors + result-detection rules, verified against the live site 2026-06. When jimeng_run.py fails on one of these, inspect the page and update ONLY this file. Arrays are tried in order. NOTE: generate_button deliberately has NO 'text=生成' fallback - it matches the home-page mode cards and misclicks.",
  "url_home": "https://jimeng.jianying.com/ai-tool/home",
  "url_generate": "https://jimeng.jianying.com/ai-tool/image/generate",
  "login_wall": ["text=登录", "text=手机号登录"],
  "mode_image": ["text=图片生成"],
  "mode_video": ["text=视频生成", "text=Seedance"],
  "prompt_input": ["[contenteditable='true'][role='textbox']", ".tiptap.ProseMirror", "[contenteditable='true']", "textarea"],
  "generate_button": ["button[class*='submit-butt']"],
  "confirm_video_button": ["button:has-text('继续生成')", "text=继续生成"],
  "download_button": ["[class*='download']", "button:has-text('下载')", "text=下载"],
  "result_scope": ["[class*='message'][class*='item']", "[class*='record'][class*='item']", "[class*='record']"],
  "max_results_per_task": 8,
  "workspace_url_marker": "workspace=",
  "downloads_dir": "D:/file/download",
  "download_glob": "jimeng-*",
  "download_timeout_ms": 120000,
  "production_methods": ["preview_download", "downloads_dir", "hd_url_variant"],
  "result_image_domain": "dreamina-sign.byteimg.com",
  "resize_marker": "aigc_resize_loss",
  "result_min_px": 200,
  "min_download_long_px": 1024,
  "result_video_markers": ["vlabvod.com", "mime_type=video_mp4"],
  "video_loading_marker": "record-loading-animation",
  "timeout_generate_seconds": 240,
  "timeout_video_seconds": 600
}
